# Django
DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
# Origins for form POSTs (scheme + host + port). Add your production URL if different.
# CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,http://your-server-ip

# Database (used when not using docker-compose)
POSTGRES_DB=vis_db
POSTGRES_USER=vis_user
POSTGRES_PASSWORD=vis_password
DATABASE_URL=postgres://vis_user:vis_password@localhost:5432/vis_db

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_FROM=noreply@example.com
EMAIL_PORT=587

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890
